# Azure Speech Service — Foundry endpoint (DefaultAzureCredential is used — no keys needed)
SPEECH_ENDPOINT=https://your-foundry-resource.cognitiveservices.azure.com/
SPEECH_REGION=eastus

# Azure AI Language Service for PII Detection (DefaultAzureCredential is used — no keys needed)
LANGUAGE_ENDPOINT=https://your-language-resource.cognitiveservices.azure.com/

# Azure Blob Storage (DefaultAzureCredential is used — no connection string needed)
AZURE_STORAGE_ACCOUNT_NAME=your-storage-account-name
AZURE_STORAGE_CONTAINER_NAME=recordings

# Server
PORT=3001
